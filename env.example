<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ai::quiz — AI-Powered Knowledge Challenge</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700;800&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0a0e17;--surface:#111827;--border:#1e293b;
    --accent:#00d4aa;--accent2:#f97316;--accent3:#a78bfa;
    --text:#e2e8f0;--muted:#64748b;
    --correct:#00d4aa;--wrong:#ef4444;--glow:rgba(0,212,170,.15);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:'JetBrains Mono',monospace;min-height:100vh;display:flex;flex-direction:column;align-items:center;overflow-x:hidden}
  body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,212,170,.03)1px,transparent 1px),linear-gradient(90deg,rgba(0,212,170,.03)1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}

  /* HEADER */
  header{position:relative;z-index:1;text-align:center;padding:28px 20px 14px;width:100%;border-bottom:1px solid var(--border);background:linear-gradient(180deg,rgba(0,212,170,.06)0%,transparent 100%)}
  .logo{font-family:'Syne',sans-serif;font-size:clamp(20px,5vw,34px);font-weight:800;letter-spacing:-1px}
  .logo .ns{color:var(--muted);font-weight:400}.logo .kw{color:var(--accent)}.logo .op{color:var(--accent2)}
  .tagline{margin-top:5px;font-size:10px;color:var(--muted);letter-spacing:3px;text-transform:uppercase}
  .topic-badge{display:none;margin-top:8px;font-size:11px;color:var(--accent3);letter-spacing:1px}
  .topic-badge.show{display:block}
  .stats-bar{display:none;gap:24px;justify-content:center;margin-top:12px;font-size:10px;color:var(--muted)}
  .stats-bar.show{display:flex}
  .stat{display:flex;flex-direction:column;align-items:center;gap:2px}
  .stat-val{font-size:19px;font-weight:700;color:var(--accent)}

  /* MAIN */
  main{position:relative;z-index:1;width:100%;max-width:720px;padding:24px 16px;display:flex;flex-direction:column;align-items:center;gap:18px}

  /* BUTTONS */
  .btn{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;padding:13px 26px;border-radius:8px;border:1px solid;cursor:pointer;letter-spacing:1px;text-transform:uppercase;transition:all .2s;white-space:nowrap}
  .btn-primary{background:var(--accent);border-color:var(--accent);color:#000}
  .btn-primary:hover:not(:disabled){background:#00b894;box-shadow:0 4px 20px rgba(0,212,170,.3);transform:translateY(-1px)}
  .btn-primary:disabled{opacity:.45;cursor:not-allowed;transform:none!important}
  .btn-ghost{background:transparent;border-color:var(--border);color:var(--muted)}
  .btn-ghost:hover{border-color:var(--muted);color:var(--text)}

  /* ANIMATIONS */
  @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
  @keyframes spin{to{transform:rotate(360deg)}}
  @keyframes slideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}

  /* SETUP */
  #setupScreen{width:100%;display:flex;flex-direction:column;align-items:center;gap:22px;animation:fadeUp .4s ease}
  .setup-title{font-family:'Syne',sans-serif;font-size:clamp(18px,4vw,26px);font-weight:800;text-align:center;line-height:1.35}
  .setup-title span{color:var(--accent)}
  .setup-sub{font-size:12px;color:var(--muted);text-align:center;line-height:1.75;max-width:480px}
  .chip-label{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;align-self:flex-start}
  .chips{display:flex;flex-wrap:wrap;gap:8px;width:100%}
  .chip{background:var(--surface);border:1px solid var(--border);border-radius:999px;padding:7px 16px;font-size:12px;font-family:'JetBrains Mono',monospace;color:var(--muted);cursor:pointer;transition:all .15s}
  .chip:hover,.chip.active{border-color:var(--accent);color:var(--accent);background:rgba(0,212,170,.06)}
  .topic-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 18px;font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s}
  .topic-input::placeholder{color:var(--muted)}
  .topic-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(0,212,170,.1)}
  .topic-input.error{border-color:var(--wrong)!important}
  .count-row{width:100%;display:flex;align-items:center;gap:14px;flex-wrap:wrap}
  .count-row label{font-size:11px;color:var(--muted);white-space:nowrap}
  .count-btns{display:flex;gap:6px}
  .count-btn{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 18px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--muted);cursor:pointer;transition:all .15s}
  .count-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(0,212,170,.08);font-weight:700}

  /* LOADING */
  #loadingScreen{display:none;flex-direction:column;align-items:center;gap:20px;padding:48px 20px;text-align:center;width:100%;animation:fadeUp .3s ease}
  .loader-ring{width:60px;height:60px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .85s linear infinite}
  .loader-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:700}
  .loader-sub{font-size:12px;color:var(--muted);line-height:1.7;max-width:340px}
  .loader-bar{width:260px;height:3px;background:var(--border);border-radius:999px;overflow:hidden}
  .loader-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent3));border-radius:999px;width:0%;transition:width .6s ease}
  .loader-steps{display:flex;flex-direction:column;gap:6px;width:100%;max-width:300px;text-align:left}
  .lstep{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--surface);border:1px solid var(--border);border-radius:6px;transition:all .3s}
  .lstep.active{border-color:var(--accent);color:var(--accent)}
  .lstep.done{border-color:rgba(0,212,170,.3);color:rgba(0,212,170,.6)}

  /* ERROR */
  #errorScreen{display:none;flex-direction:column;align-items:center;gap:16px;padding:40px 20px;text-align:center;width:100%;animation:fadeUp .3s ease}
  .error-icon{font-size:42px}
  .error-title{font-family:'Syne',sans-serif;font-size:21px;font-weight:700;color:var(--wrong)}
  .error-msg{font-size:12px;color:var(--muted);max-width:420px;line-height:1.7}
  .error-detail{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px 16px;font-size:11px;color:var(--muted);max-width:520px;width:100%;word-break:break-all;text-align:left}
  .error-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}

  /* GAME */
  #gameArea{display:none;flex-direction:column;align-items:center;gap:18px;width:100%;animation:fadeUp .3s ease}
  .progress-wrap{width:100%;height:3px;background:var(--border);border-radius:999px;overflow:hidden}
  .progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent3));border-radius:999px;transition:width .5s ease}
  .trail{display:flex;gap:5px;flex-wrap:wrap;justify-content:center}
  .trail-dot{width:10px;height:10px;border-radius:50%;background:var(--border);transition:background .3s}
  .trail-dot.c{background:var(--correct);box-shadow:0 0 6px var(--correct)}
  .trail-dot.w{background:var(--wrong)}
  .category-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.3);border-radius:999px;padding:4px 14px;font-size:10px;color:var(--accent3);letter-spacing:1px;text-transform:uppercase}
  .prompt-area{width:100%;text-align:center}
  .question-num{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px}
  .question-text{font-family:'Syne',sans-serif;font-size:clamp(15px,3.5vw,21px);font-weight:700;color:var(--text);line-height:1.4}
  .question-hint{font-size:11px;color:var(--muted);margin-top:6px}

  /* CODE CARD */
  .question-card{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:box-shadow .3s}
  .question-card:hover{box-shadow:0 0 30px var(--glow)}
  .card-header{background:rgba(0,212,170,.07);border-bottom:1px solid var(--border);padding:9px 16px;display:flex;align-items:center;gap:8px;font-size:11px;color:var(--muted)}
  .dot{width:8px;height:8px;border-radius:50%}.dot.r{background:#ef4444}.dot.y{background:#f59e0b}.dot.g{background:#22c55e}
  .filename{margin-left:auto;color:var(--accent3);font-size:11px}
  .code-block{padding:18px 20px;font-size:clamp(11px,2.2vw,13px);line-height:1.9;overflow-x:auto;white-space:pre}
  .sk{color:#60a5fa}.st{color:#f472b6}.ss{color:#4ade80}.sn{color:#fb923c}.sc{color:#6b7280;font-style:italic}

  /* OPTIONS */
  .options-grid{width:100%;display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .option-btn{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px 15px;cursor:pointer;text-align:left;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:clamp(11px,1.9vw,13px);transition:all .15s ease;position:relative;overflow:hidden;line-height:1.4}
  .option-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent,rgba(0,212,170,.05));opacity:0;transition:opacity .2s}
  .option-btn:hover:not(:disabled)::before{opacity:1}
  .option-btn:hover:not(:disabled){border-color:var(--accent);transform:translateY(-1px);box-shadow:0 4px 15px rgba(0,212,170,.1)}
  .option-btn:disabled{cursor:not-allowed}
  .option-btn.correct{background:rgba(0,212,170,.12);border-color:var(--correct);color:var(--correct);box-shadow:0 0 20px rgba(0,212,170,.2)}
  .option-btn.wrong{background:rgba(239,68,68,.08);border-color:var(--wrong);color:var(--wrong)}
  .option-btn.reveal{background:rgba(0,212,170,.06);border-color:rgba(0,212,170,.3);color:var(--accent)}
  .opt-label{display:inline-block;width:22px;height:22px;background:var(--border);border-radius:4px;text-align:center;line-height:22px;font-size:10px;font-weight:700;margin-right:8px;margin-bottom:2px;color:var(--muted);transition:all .15s;vertical-align:middle}
  .correct .opt-label{background:var(--correct);color:#000}.wrong .opt-label{background:var(--wrong);color:#fff}.reveal .opt-label{background:rgba(0,212,170,.3);color:var(--accent)}
  .opt-detail{display:block;margin-top:3px;font-size:11px;color:var(--muted)}
  .correct .opt-detail{color:rgba(0,212,170,.7)}.wrong .opt-detail{color:rgba(239,68,68,.6)}.reveal .opt-detail{color:rgba(0,212,170,.6)}

  /* FEEDBACK */
  .feedback{width:100%;padding:14px 18px;border-radius:10px;font-size:13px;line-height:1.65;display:none;border:1px solid;animation:slideIn .3s ease}
  .feedback.show{display:block}
  .feedback.correct-fb{background:rgba(0,212,170,.08);border-color:rgba(0,212,170,.3)}
  .feedback.wrong-fb{background:rgba(239,68,68,.06);border-color:rgba(239,68,68,.3)}
  .feedback-title{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;margin-bottom:6px}
  .correct-fb .feedback-title{color:var(--correct)}.wrong-fb .feedback-title{color:var(--wrong)}
  .feedback-body{color:var(--muted);font-size:12px}
  .feedback-body code{color:var(--accent3);background:rgba(167,139,250,.1);padding:1px 5px;border-radius:3px}
  .controls{display:flex;gap:12px;justify-content:center;width:100%}

  /* END */
  #endScreen{display:none;flex-direction:column;align-items:center;gap:16px;text-align:center;padding:32px 20px;width:100%;max-width:520px;animation:fadeUp .5s ease}
  .end-grade{font-family:'Syne',sans-serif;font-size:80px;font-weight:800;line-height:1;background:linear-gradient(135deg,var(--accent),var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .end-label{font-size:10px;color:var(--muted);letter-spacing:3px;text-transform:uppercase}
  .end-msg{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--text)}
  .end-sub{font-size:12px;color:var(--muted);line-height:1.7;max-width:400px}
  .score-breakdown{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;width:100%;max-width:360px}
  .sb-item{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 8px}
  .sb-val{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--accent)}
  .sb-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:4px}
  .end-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
</style>
</head>
<body>

<header>
  <div class="logo"><span class="ns">ai::</span><span class="kw">quiz</span><span class="op">&lt;</span><span class="kw">topic</span><span class="op">&gt;</span></div>
  <div class="tagline">Claude-Powered Adaptive Knowledge Challenge</div>
  <div class="topic-badge" id="topicBadge">// topic: —</div>
  <div class="stats-bar" id="statsBar">
    <div class="stat"><span class="stat-val" id="scoreDisplay">0</span><span>SCORE</span></div>
    <div class="stat"><span class="stat-val" id="streakDisplay">0</span><span>STREAK</span></div>
    <div class="stat"><span class="stat-val" id="qDisplay">1/15</span><span>QUESTION</span></div>
  </div>
</header>

<main>

  <!-- SETUP -->
  <div id="setupScreen">
    <div class="setup-title">What do you want to<br><span>be quizzed on?</span></div>
    <div class="setup-sub">Type any programming topic — Claude generates <strong>15–25 unique questions</strong> tailored to your subject instantly.</div>
    <div class="chip-label">Quick picks →</div>
    <div class="chips">
      <div class="chip" onclick="setChip(this,'std::map in C++')">std::map</div>
      <div class="chip" onclick="setChip(this,'std::vector in C++')">std::vector</div>
      <div class="chip" onclick="setChip(this,'C++ smart pointers')">Smart Pointers</div>
      <div class="chip" onclick="setChip(this,'C++ templates and generics')">Templates</div>
      <div class="chip" onclick="setChip(this,'C++ STL algorithms')">STL Algorithms</div>
      <div class="chip" onclick="setChip(this,'C++ multithreading and concurrency')">Concurrency</div>
      <div class="chip" onclick="setChip(this,'C++ move semantics and rvalue references')">Move Semantics</div>
      <div class="chip" onclick="setChip(this,'Object-oriented programming in C++')">OOP in C++</div>
      <div class="chip" onclick="setChip(this,'Python data structures')">Python DS</div>
      <div class="chip" onclick="setChip(this,'JavaScript promises and async/await')">JS Async</div>
      <div class="chip" onclick="setChip(this,'SQL joins and queries')">SQL</div>
      <div class="chip" onclick="setChip(this,'Big-O complexity analysis')">Big-O</div>
    </div>
    <input class="topic-input" id="topicInput" type="text" placeholder="e.g. Binary trees in C++, Python decorators, REST APIs..." maxlength="140"/>
    <div class="count-row">
      <label>Number of questions:</label>
      <div class="count-btns">
        <button class="count-btn active" onclick="setCount(this,15)">15</button>
        <button class="count-btn" onclick="setCount(this,20)">20</button>
        <button class="count-btn" onclick="setCount(this,25)">25</button>
      </div>
    </div>
    <button class="btn btn-primary" id="startBtn" onclick="startQuiz()">⚡ Generate Quiz →</button>
  </div>

  <!-- LOADING -->
  <div id="loadingScreen">
    <div class="loader-ring"></div>
    <div class="loader-title">Generating your quiz…</div>
    <div class="loader-sub">Claude is crafting questions about <em id="loaderTopic" style="color:var(--accent3)">your topic</em>.</div>
    <div class="loader-bar"><div class="loader-fill" id="loaderFill"></div></div>
    <div class="loader-steps" id="loaderSteps">
      <div class="lstep" id="ls0"><span>🔍</span> Analyzing topic</div>
      <div class="lstep" id="ls1"><span>🧠</span> Crafting questions</div>
      <div class="lstep" id="ls2"><span>🎯</span> Building answer choices</div>
      <div class="lstep" id="ls3"><span>💻</span> Writing code snippets</div>
      <div class="lstep" id="ls4"><span>✅</span> Finalizing quiz</div>
    </div>
  </div>

  <!-- ERROR -->
  <div id="errorScreen">
    <div class="error-icon">⚠️</div>
    <div class="error-title">Generation Failed</div>
    <div class="error-msg" id="errorMsg">Something went wrong while generating your quiz.</div>
    <div class="error-detail" id="errorDetail" style="display:none"></div>
    <div class="error-actions">
      <button class="btn btn-primary" onclick="retryQuiz()">↺ Try Again</button>
      <button class="btn btn-ghost" onclick="goSetup()">← Change Topic</button>
    </div>
  </div>

  <!-- GAME -->
  <div id="gameArea">
    <div class="progress-wrap"><div class="progress-fill" id="progressBar" style="width:0%"></div></div>
    <div class="trail" id="trail"></div>
    <div class="category-badge" id="categoryBadge">⬡ LOADING</div>
    <div class="prompt-area">
      <div class="question-num" id="qNum">QUESTION 1</div>
      <div class="question-text" id="qText"></div>
      <div class="question-hint" id="qHint"></div>
    </div>
    <div class="question-card" id="codeCard" style="display:none">
      <div class="card-header">
        <div class="dot r"></div><div class="dot y"></div><div class="dot g"></div>
        <span class="filename" id="cardFilename">snippet</span>
      </div>
      <div class="code-block" id="codeBlock"></div>
    </div>
    <div class="options-grid" id="optionsGrid"></div>
    <div class="feedback" id="feedback">
      <div class="feedback-title" id="fbTitle"></div>
      <div class="feedback-body" id="fbBody"></div>
    </div>
    <div class="controls" id="controls" style="display:none">
      <button class="btn btn-ghost" onclick="skipQuestion()">Skip →</button>
      <button class="btn btn-primary" id="nextBtn" onclick="nextQuestion()">Next →</button>
    </div>
  </div>

  <!-- END -->
  <div id="endScreen">
    <div class="end-grade" id="endGrade">A+</div>
    <div class="end-label">Final Score</div>
    <div class="end-msg" id="endMsg">Expert!</div>
    <div class="end-sub" id="endSub"></div>
    <div class="score-breakdown">
      <div class="sb-item"><div class="sb-val" id="sbCorrect">0</div><div class="sb-label">Correct</div></div>
      <div class="sb-item"><div class="sb-val" id="sbScore">0</div><div class="sb-label">Points</div></div>
      <div class="sb-item"><div class="sb-val" id="sbPct">0%</div><div class="sb-label">Accuracy</div></div>
    </div>
    <div class="trail" id="endTrail"></div>
    <div class="end-actions">
      <button class="btn btn-primary" onclick="retryQuiz()">↺ Same Topic</button>
      <button class="btn btn-ghost" onclick="goSetup()">← New Topic</button>
    </div>
  </div>

</main>

<script>
// ── State ─────────────────────────────────────────────────────────────────────
let QUESTIONS=[], currentQ=0, score=0, streak=0;
let answered=false, results=[], shuffledOptions=[];
let selectedTopic='', selectedCount=15;

// ── Setup ─────────────────────────────────────────────────────────────────────
function setChip(el,val){
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const inp=document.getElementById('topicInput');
  inp.value=val; inp.classList.remove('error');
}
function setCount(el,n){
  document.querySelectorAll('.count-btn').forEach(b=>b.classList.remove('active'));
  el.classList.add('active'); selectedCount=n;
}
document.getElementById('topicInput').addEventListener('input',function(){
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  this.classList.remove('error');
});
document.getElementById('topicInput').addEventListener('keydown',e=>{if(e.key==='Enter')startQuiz()});

// ── Screen control ────────────────────────────────────────────────────────────
function showScreen(id){
  ['setupScreen','loadingScreen','errorScreen','gameArea','endScreen'].forEach(s=>{
    document.getElementById(s).style.display=(s===id)?'flex':'none';
  });
}

// ── Syntax highlighter ────────────────────────────────────────────────────────
function highlight(code){
  if(!code)return'';
  const e=s=>s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  let s=e(code);
  const rules=[
    [/(\/\/[^\n]*)/g,'sc'],
    [/(\/\*[\s\S]*?\*\/)/g,'sc'],
    [/("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'|`(?:[^`\\]|\\.)*`)/g,'ss'],
    [/\b(\d+\.?\d*[fFuUlL]*)\b/g,'sn'],
    [/\b(auto|const|constexpr|int|float|double|bool|void|char|long|short|unsigned|nullptr|true|false|new|delete|return|if|else|for|while|do|switch|case|default|break|continue|class|struct|union|enum|public|private|protected|virtual|override|template|typename|using|namespace|include|typedef|explicit|inline|static|extern|noexcept|operator|this|throw|try|catch|def|import|from|pass|lambda|yield|async|await|let|const|var|function|=>)\b/g,'sk'],
    [/\b(string|vector|map|unordered_map|set|list|deque|pair|tuple|shared_ptr|unique_ptr|weak_ptr|make_shared|make_unique|move|forward|cout|cin|endl|std|print|len|range|None|True|False|console|Promise|async)\b/g,'st'],
  ];
  let tokens=[{t:s,c:null}];
  for(const[re,cls]of rules){
    const next=[];
    for(const tok of tokens){
      if(tok.c!==null){next.push(tok);continue}
      let last=0,m;re.lastIndex=0;
      while((m=re.exec(tok.t))!==null){
        if(m.index>last)next.push({t:tok.t.slice(last,m.index),c:null});
        next.push({t:m[0],c:cls});
        last=m.index+m[0].length;
      }
      if(last<tok.t.length)next.push({t:tok.t.slice(last),c:null});
    }
    if(next.length>0)tokens=next;
  }
  return tokens.map(t=>t.c?`<span class="${t.c}">${t.t}</span>`:t.t).join('');
}

function h(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

// ── Start quiz ────────────────────────────────────────────────────────────────
async function startQuiz(){
  const topic=document.getElementById('topicInput').value.trim();
  if(!topic){
    document.getElementById('topicInput').classList.add('error');
    document.getElementById('topicInput').focus();
    return;
  }
  selectedTopic=topic;
  document.getElementById('topicBadge').textContent=`// topic: ${topic}`;
  document.getElementById('topicBadge').classList.add('show');
  document.getElementById('statsBar').classList.remove('show');

  showScreen('loadingScreen');
  document.getElementById('loaderTopic').textContent=topic;
  document.getElementById('loaderFill').style.width='0%';

  // Animate steps
  const stepIds=['ls0','ls1','ls2','ls3','ls4'],pcts=[15,35,60,80,95];
  stepIds.forEach(id=>{document.getElementById(id).className='lstep'});
  let si=0;
  const timer=setInterval(()=>{
    if(si<stepIds.length){
      if(si>0)document.getElementById(stepIds[si-1]).className='lstep done';
      document.getElementById(stepIds[si]).className='lstep active';
      document.getElementById('loaderFill').style.width=pcts[si]+'%';
      si++;
    }else clearInterval(timer);
  },700);

  try{
    // ✅ Call our Express backend — API key stays on the server
    const res=await fetch('/api/generate-quiz',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({topic,count:selectedCount})
    });
    const data=await res.json();
    clearInterval(timer);

    if(!res.ok) throw new Error(data.error||`Server error ${res.status}`);

    QUESTIONS=data.questions;
    currentQ=0;score=0;streak=0;results=[];

    stepIds.forEach(id=>document.getElementById(id).className='lstep done');
    document.getElementById('loaderFill').style.width='100%';

    document.getElementById('scoreDisplay').textContent=0;
    document.getElementById('streakDisplay').textContent=0;
    document.getElementById('qDisplay').textContent=`1/${QUESTIONS.length}`;
    document.getElementById('statsBar').classList.add('show');

    await new Promise(r=>setTimeout(r,350));
    showScreen('gameArea');
    renderQuestion();

  }catch(err){
    clearInterval(timer);
    showScreen('errorScreen');
    const isNet=err.message.toLowerCase().includes('fetch')||err.message.toLowerCase().includes('network')||err.message.toLowerCase().includes('failed');
    document.getElementById('errorMsg').textContent=
      isNet?'Network error — make sure the server is running and try again.':
      err.message||'Something went wrong generating your quiz.';
    const det=document.getElementById('errorDetail');
    det.style.display='block';
    det.textContent=err.message.slice(0,300);
  }
}

function retryQuiz(){startQuiz()}
function goSetup(){
  document.getElementById('statsBar').classList.remove('show');
  document.getElementById('topicBadge').classList.remove('show');
  showScreen('setupScreen');
}

// ── Game ──────────────────────────────────────────────────────────────────────
function shuffle(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]]}
  return a;
}
function buildTrail(){
  const t=document.getElementById('trail');t.innerHTML='';
  QUESTIONS.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='trail-dot'+(i<results.length?(results[i]?' c':' w'):'');
    t.appendChild(d);
  });
}
function renderQuestion(){
  const q=QUESTIONS[currentQ];answered=false;
  document.getElementById('progressBar').style.width=(currentQ/QUESTIONS.length*100)+'%';
  document.getElementById('qDisplay').textContent=`${currentQ+1}/${QUESTIONS.length}`;
  document.getElementById('qNum').textContent=`QUESTION ${currentQ+1} OF ${QUESTIONS.length}`;
  document.getElementById('qText').textContent=q.text||'';
  document.getElementById('qHint').textContent=q.hint?`Hint: ${q.hint}`:'';
  document.getElementById('categoryBadge').textContent='⬡ '+(q.category||'GENERAL');

  const cc=document.getElementById('codeCard');
  if(q.code&&String(q.code).trim()){
    cc.style.display='block';
    document.getElementById('codeBlock').innerHTML=highlight(String(q.code));
    const t=selectedTopic.toLowerCase();
    const ext=t.includes('python')?'.py':t.includes('javascript')||t.includes(' js')?'.js':t.includes('java')&&!t.includes('javascript')?'.java':t.includes('sql')?'.sql':'.cpp';
    document.getElementById('cardFilename').textContent=`q${currentQ+1}${ext}`;
  }else cc.style.display='none';

  shuffledOptions=shuffle((q.options||[]).map(o=>({...o})));
  const labels=['A','B','C','D'],grid=document.getElementById('optionsGrid');
  grid.innerHTML='';
  shuffledOptions.forEach((opt,i)=>{
    const btn=document.createElement('button');
    btn.className='option-btn';
    btn.innerHTML=`<span class="opt-label">${labels[i]}</span>${h(opt.label)}<span class="opt-detail">${h(opt.detail||'')}</span>`;
    btn.onclick=()=>selectOption(i);
    grid.appendChild(btn);
  });

  document.getElementById('feedback').className='feedback';
  document.getElementById('controls').style.display='none';
  document.getElementById('nextBtn').textContent=currentQ===QUESTIONS.length-1?'See Results →':'Next →';
  buildTrail();
}

function selectOption(idx){
  if(answered)return;answered=true;
  const q=QUESTIONS[currentQ],isCorrect=!!shuffledOptions[idx].correct;
  document.querySelectorAll('.option-btn').forEach((btn,i)=>{
    btn.disabled=true;
    if(i===idx)btn.classList.add(isCorrect?'correct':'wrong');
    else if(shuffledOptions[i].correct)btn.classList.add('reveal');
  });
  if(isCorrect){score+=10+streak*2;streak++}else{streak=0}
  results.push(isCorrect);
  document.getElementById('scoreDisplay').textContent=score;
  document.getElementById('streakDisplay').textContent=streak;
  buildTrail();
  const fb=document.getElementById('feedback');
  fb.className=isCorrect?'feedback correct-fb show':'feedback wrong-fb show';
  document.getElementById('fbTitle').textContent=isCorrect?(q.correct_title||'✓ Correct!'):'✗ Not quite — here\'s why:';
  document.getElementById('fbBody').innerHTML=q.explanation||'';
  document.getElementById('controls').style.display='flex';
}

function nextQuestion(){currentQ++;if(currentQ>=QUESTIONS.length)showEndScreen();else renderQuestion()}
function skipQuestion(){
  if(!answered){results.push(false);streak=0;document.getElementById('streakDisplay').textContent=0;buildTrail()}
  nextQuestion();
}

function showEndScreen(){
  const correct=results.filter(Boolean).length,pct=Math.round(correct/QUESTIONS.length*100);
  let grade,msg,sub;
  if(pct>=90){grade='A+';msg='Absolute Expert!';sub=`Outstanding mastery of "${selectedTopic}". ${correct}/${QUESTIONS.length} correct!`}
  else if(pct>=80){grade='A';msg='Advanced Level';sub=`Strong understanding of "${selectedTopic}". A few edge cases to review.`}
  else if(pct>=70){grade='B';msg='Solid Foundation';sub=`Good grasp of "${selectedTopic}". Review the missed questions for deeper insight.`}
  else if(pct>=50){grade='C';msg='Keep Practicing';sub=`Decent start with "${selectedTopic}". Revisit the fundamentals and retry.`}
  else{grade='D';msg='Back to Basics';sub=`"${selectedTopic}" needs more study. Read the explanations, then try again!`}
  document.getElementById('endGrade').textContent=grade;
  document.getElementById('endMsg').textContent=msg;
  document.getElementById('endSub').textContent=sub;
  document.getElementById('sbCorrect').textContent=`${correct}/${QUESTIONS.length}`;
  document.getElementById('sbScore').textContent=score;
  document.getElementById('sbPct').textContent=pct+'%';
  const et=document.getElementById('endTrail');et.innerHTML='';
  results.forEach(r=>{const d=document.createElement('div');d.className='trail-dot '+(r?'c':'w');et.appendChild(d)});
  showScreen('endScreen');
}

// ── Keyboard shortcuts ────────────────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  if(document.getElementById('gameArea').style.display==='flex'){
    if(!answered){const m={'1':0,'2':1,'3':2,'4':3,a:0,b:1,c:2,d:3};if(m[e.key]!==undefined)selectOption(m[e.key])}
    else if(e.key==='Enter'||e.key==='ArrowRight')nextQuestion();
  }
});

showScreen('setupScreen');
</script>
</body>
</html>
